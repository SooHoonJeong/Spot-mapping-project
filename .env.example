# server
SERVER_PORT=your_server_port

# Database
DB_HOST=your_db_service_name
DB_INTERNAL_PORT=your_db_internal_port
DB_EXTERNAL_PORT=your_db_external_port
DB_NAME=your_db_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Redis
REDIS_HOST=your_redis_service_name
REDIS_INTERNAL_PORT=your_redis_internal_port
REDIS_EXTERNAL_PORT=your_redis_external_port
REDIS_PASSWORD=your_redis_password

# Mail
MAIL_USERNAME=your_email_address
MAIL_PASSWORD=your_app_password

# Encryption
ENCRYPT_SECRET_KEY=your_32bit_secret_key

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRE_MS=your_access_token_ms
JWT_REFRESH_TOKEN_EXPIRE_MS=your_refresh_token_ms

# Monitoring
PROMETHEUS_EXTERNAL_PORT=your_prometheus_port
GRAFANA_EXTERNAL_PORT=your_grafana_port

# File
MAX_FILE_SIZE=your_max_file_size
MAX_REQUEST_SIZE=your_max_request_size
UPLOAD_DIR=your_upload_directory